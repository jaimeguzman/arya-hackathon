# IntakeAI environment variables — copy to .env and fill in real values.
# Never commit .env.

# PostgreSQL (must point at an allowlisted demo database — safety guarantee #1)
DATABASE_URL=postgresql://intakeai:intakeai@localhost:5432/intakeai_demo

# Neo4j knowledge graph
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Redis ephemeral state
REDIS_URL=redis://localhost:6379/0

# Twilio (mandatory telephony provider)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Gemini Flash (single tokenizing LLM wrapper only)
GEMINI_API_KEY=

# Public URL for Twilio webhooks (ngrok tunnel)
PUBLIC_BASE_URL=
